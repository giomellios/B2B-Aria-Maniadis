{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:server": "VENDURE_ROLE=server ts-node ./src/index.ts",
    "dev:worker": "VENDURE_ROLE=worker ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "build": "tsc && vite build",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/lib-storage": "^3.1015.0",
    "@vendure/asset-server-plugin": "3.5.3",
    "@vendure/core": "3.5.3",
    "@vendure/dashboard": "3.5.3",
    "@vendure/email-plugin": "3.5.3",
    "@vendure/graphiql-plugin": "3.5.3",
    "dotenv": "17.3.1",
    "pg": "8.18.0"
  },
  "devDependencies": {
    "@vendure/cli": "3.5.3",
    "concurrently": "9.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
